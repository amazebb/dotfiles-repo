# shellcheck disable=SC2329,SC2034
# Function to set up custom zsh prompt with git status
setup_prompt() {
    # Enable command substitution in prompt
    setopt PROMPT_SUBST
    GIT_STLINE=""

    prompt_segment() {
        # Wrap in %{ %} to ensure the %K{blue} is not interpreted as spaces
        echo -n "%{%K{blue}%}%60<..<%~"
    }

    prompt_segment_tail() {
        RIGHT_ARROW='\uE0B0'
        GIT_BRANCH_SYMBOL='\uE0A0'
        COLORED_RIGHT_ARROW='%{%F{blue}%}'$RIGHT_ARROW'%f'
        # Prevent Mac Terminal.app brightening font color with no background
        # https://apple.stackexchange.com/questions/282911/
        # prevent-mac-terminal-brightening-font-color-with-no-background/446604#446604
        # Setting background to an out of range value works, %k and %K{256} do not work
        # Not needed for Kitty
        if [[ -z "$KITTY_WINDOW_ID" ]]; then
            RESET_BACKGROUND='%{\e[48;5;256m%}'
        else
            RESET_BACKGROUND='%k'
        fi
        if [[ -n ${GIT_STLINE} ]]; then
            if [[ ${GIT_STLINE} =~ [+~?] ]]; then
                BG_COLOR='%{%K{yellow}%}'
                FG_COLOR='%{%F{yellow}%}'
            else
                BG_COLOR='%{%K{green}%}'
                FG_COLOR='%{%F{green}%}'
            fi
            echo -n "$BG_COLOR$COLORED_RIGHT_ARROW $GIT_BRANCH_SYMBOL ${GIT_STLINE}$FG_COLOR $RESET_BACKGROUND$RIGHT_ARROW%f%k "
        else
            echo -n "$RESET_BACKGROUND$COLORED_RIGHT_ARROW%k "
        fi
    }

    # Prompt segment for user@host without triangle
    user_host_segment() {
        ENABLE_USER_HOST=0
        if [[ ${ENABLE_USER_HOST} -eq 1 ]]; then
            echo -n "%n@%m"
        else
            echo ""
        fi
    }

    # Update Git status before each prompt
    precmd() {
        # Update the Git status line
        GIT_STLINE=$(git-wrapper stline)
    }

    # Build left prompt dynamically to include git status
    precmd_prompt() {
        left_prompt=$(user_host_segment)
        left_prompt+=$(prompt_segment)
        left_prompt+=$(prompt_segment_tail)
        PS1="${left_prompt}"
    }

    # Update right prompt dynamically
    rprompt_segment() {
        LEFT_ARROW=$'\uE0B2'
        PYTHON_SYMBOL=$'\uE606'
        PYTHON_VENV_STATUS=""
        if [[ -z "$KITTY_WINDOW_ID" ]]; then
            RESET_BACKGROUND=$'%{\e[48;5;256m%}'
        else
            RESET_BACKGROUND=''
        fi
        if [[ -n "$VIRTUAL_ENV" ]]; then
            venv_parent="${VIRTUAL_ENV%/*}"
            if [[ "$PWD" == "$venv_parent"/* || "$PWD" == "$venv_parent" ]]; then
                PYTHON_VENV_STATUS="%{%F{blue}%}$LEFT_ARROW%f%{%K{blue}%}$PYTHON_SYMBOL"
            else
                PYTHON_VENV_STATUS="%{%F{magenta}%}$LEFT_ARROW%f%{%K{magenta}%}$PYTHON_SYMBOL"
            fi
        fi
        # See Chapter 13: Prompt Expansion in Z Shell Manual for more info
        RPS1="${RESET_BACKGROUND}${PYTHON_VENV_STATUS} %(?.%{%F{green}%}.%{%F{red}%})${LEFT_ARROW}%f%(?.%{%K{green}%}.%{%K{red}%}) %*%f%k"
        # %(?.X.Y)    : Conditional: X if last command succeeded (exit code 0), Y if failed
    }

    # Hook precmd to update prompt
    precmd_functions+=(precmd_prompt rprompt_segment)
}
