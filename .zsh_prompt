# shellcheck disable=SC2329,SC2034
# Function to set up custom ZSH prompt with git status
typeset -gA ZZP
ZZP=(
    [fgt]='%{%F{15}%}'     # Foreground text color
    [k]='%{\e[48;5;256m%}' # Reset background for 256 color macOS Terminal
    [+]='yellow'           # Git working tree changes color
    [ok]='green'           # Git working tree clean color
    [color]='blue'         # Main prompt color
    [host]=''              # Display user@host ("%n@%m"), or hide ("")
    [width]='40'           # Width of the prompt
    [ra]='\uE0B0'          # PS1 right trailing symbol
    [la]=$'\uE0B2'         # RPS1 left leading symbol
    [git]='\uE0A0'         # Git branch symbol
    [python]=$'\uE606'     # Python symbol
 )

setup_prompt() {
    # Enable command substitution in prompt
    setopt PROMPT_SUBST

    prompt_segment() {
        # Wrap in %{ %} to ensure the %K{blue} is not interpreted as spaces
        echo -n "%{%K{blue}%}${ZZP[fgt]}%${ZZP[width]}<..<%~"
    }

    prompt_segment_tail() {
        COLORED_RIGHT_ARROW='%{%F{blue}%}'${ZZP[ra]}'%f'
        # In macOS 15.x and prior, prevent Terminal.app brightening font color with no background:
        # https://apple.stackexchange.com/questions/282911/
        # prevent-mac-terminal-brightening-font-color-with-no-background/446604#446604
        # Setting background to an out of range value works, %k and %K{256} do not work.
        # Not needed for Kitty and terminals that support truecolor
        RESET_BG='%k'
        if [[ -z "$KITTY_WINDOW_ID" ]]; then
            RESET_BG+=${ZZP[k]}
        fi
        if [[ -n ${GIT_STLINE} ]]; then
            if [[ ${GIT_STLINE} =~ [+~?] ]]; then
                BG_COLOR='%{%K{yellow}%}'
                FG_COLOR='%{%F{yellow}%}'
            else
                BG_COLOR='%{%K{green}%}'
                FG_COLOR='%{%F{green}%}'
            fi
            echo -n "$BG_COLOR$COLORED_RIGHT_ARROW ${ZZP[fgt]}${ZZP[git]} ${GIT_STLINE}$FG_COLOR $RESET_BG${ZZP[ra]}%f "
        else
            echo -n "$RESET_BG$COLORED_RIGHT_ARROW "
        fi
    }

    # Update Git status before each prompt
    precmd() {
        GIT_STLINE=$(git-wrapper stline)
    }

    # Build left prompt dynamically to include git status
    precmd_prompt() {
        left_prompt=${ZZP[host]} 
        left_prompt+=$(prompt_segment)
        left_prompt+=$(prompt_segment_tail)
        PS1="${left_prompt}"
    }

    get_relative_depth() {
        # Calculate relative path from VENV to current directory as "../" notation
        # Given a base path (typically a Python virtual environment parent), returns
        # a string of "../" repeated for each directory level between the base and PWD.
        local VENV="$1"
        local relative result
        local depth=0

        [[ "$PWD" != "$VENV" ]] && relative="${PWD#"$VENV"/}"

        [[ -n "$relative" ]] && depth=$(( ${#${relative//[^\/]}} + 1 ))

        for ((i = 0; i < depth; i++)); do result+="../"; done

        echo "$result"
    }

    # Update right prompt dynamically
    rprompt_segment() {
        LEFT_ARROW=$'\uE0B2'
        PYTHON_SYMBOL=$'\uE606'
        PYTHON_VENV=""

        RESET_BG='%k'
        if [[ -z "$KITTY_WINDOW_ID" ]]; then
            RESET_BG+=$'%{\e[48;5;256m%}'
        fi

        if [[ -n "$VIRTUAL_ENV" ]]; then
            VENV="${VIRTUAL_ENV%/*}"

            if [[ "$PWD" == "$VENV"/* || "$PWD" == "$VENV" ]]; then
                FG_COLOR='%{%F{blue}%}'
                BG_COLOR='%{%K{blue}%}'
                relative_path=$(get_relative_depth "$VENV")
                VENV_STR="$relative_path${VIRTUAL_ENV##*/}"
            else
                FG_COLOR='%{%F{magenta}%}'
                BG_COLOR='%{%K{magenta}%}'
                local tmp=${VENV/#$PWD/}
                VENV_STR="${tmp/#$HOME/~}"
            fi
            PYTHON_VENV="$FG_COLOR$LEFT_ARROW"
            PYTHON_VENV+="%f$BG_COLOR$PYTHON_SYMBOL $VENV_STR "
        fi

        # See Chapter 13: Prompt Expansion in Z Shell Manual for more info
        FG_OK='%{%F{green}%}'
        BG_OK='%{%K{green}%}'
        FG_ERROR='%{%F{red}%}'
        BG_ERROR='%{%K{red}%}'

        RPS1="$RESET_BG$PYTHON_VENV"
        RPS1+="%(?.$FG_OK.$FG_ERROR)$LEFT_ARROW"
        RPS1+="${ZZP[fgt]}%(?.$BG_OK.$BG_ERROR) %*%f%k"
    }

    # Final hook to update prompt
    precmd_functions+=(precmd_prompt rprompt_segment)
}
