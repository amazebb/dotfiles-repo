[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = master
	defaultObjectFormat = sha1
[credential]
	helper = osxkeychain
[core]
	excludesfile = ~/.gitignore_global
	editor = nvim
	pager = bat
[user]
	name = x626f
	email = -----------------@icloud.com
[diff]
	tool = opendiff
[dotfiles]
	tracked-folders = ~/.local/scripts,~/.config/nvim
[alias]
	c = commit
	cv = commit -v
	cva = commit -va
	co = checkout
	d = diff
	pom = push origin master
	s = status
[difftool]
	prompt = false
[github]
	user = x626f
