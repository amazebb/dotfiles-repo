#!/usr/bin/env zsh
# Interactive man page/tldr searcher with fzf, bat, and key bindings

fzf-man() {
    cyan=$(tput setaf 6)
    blue=$(tput setaf 4)
    res=$(tput sgr0)
    bld=$(tput bold)
    color_awk='{ $1=cyan bld $1; $2=res blue $2; } 1'
    esc_cyan=$(printf '%q' "$cyan")
    esc_blue=$(printf '%q' "$blue")
    esc_res=$(printf '%q' "$res")
    esc_bld=$(printf '%q' "$bld")
    manpage="echo {} | sed 's/\\([[:alnum:][:punct:]]*\\) (\\([[:alnum:]]*\\)).*/\\2 \\1/'"
    batman="${manpage} | xargs -r man | col -bx | bat --language=man --plain --color always --theme=\"Monokai Extended\""
    man -k . | sort -r | awk -v cyan="$cyan" -v blue="$blue" -v res="$res" -v bld="$bld" "$color_awk" |
        fzf \
            -q "$1" \
            --ansi \
            --style full \
            --header 'alt-m:man, alt-t:TLDR (common)' \
            --tiebreak=begin \
            --prompt=' Man > ' \
            --preview-window '50%,rounded,<50(up,85%,border-bottom)' \
            --preview "${batman}" \
            --bind "enter:execute(${manpage} | xargs -r man)" \
            --bind "alt-m:+reload(man -k . | sort -r | awk -v cyan=${esc_cyan} -v blue=${esc_blue} -v res=${esc_res} -v bld=${esc_bld} '${color_awk}')+change-preview(${batman})+change-prompt( Man > )" \
            --bind "alt-t:+reload(comm -12 <(tldr -l -p osx | sed '1d' | sort) <(man -k . | awk '{print \$1}' | sort -u) | sort -r | awk -v cyan=${esc_cyan} -v blue=${esc_blue} -v res=${esc_res} -v bld=${esc_bld} '${color_awk}')+change-preview(tldr -C {1} -p osx)+change-prompt(TLDR > )"
    if [[ $ZLE_STATE == *widget* ]]; then
        [[ -o zle ]] && zle reset-prompt
    fi
}

# Register the widget
zle -N fzf-man

# Bind Ctrl-H to launch the fzf-man widget
bindkey '^h' fzf-man
