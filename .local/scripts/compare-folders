#!/usr/bin/env bash
# Compare folders using diff command.

if [ $# -lt 2 ]; then
  echo "Usage: $0 <folder1> <folder2> [-f filter] [-w] [-s|-u] [-c]"
  echo "  -f: file filter (e.g., '*.sh')"
  echo "  -w: ignore whitespace differences"
  echo "  -s: show differences side-by-side"
  echo "  -u: show differences in unified format"
  echo "  -c: show colored differences (requires colordiff)"
  exit 1
fi

FOLDER1="$1"
FOLDER2="$2"
FILTER="*"
IGNORE_WHITESPACE=false
SHOW_DIFF=false
DIFF_FORMAT=""
COLOR_DIFF=false

shift 2
while getopts "f:wsuc" opt; do
  case $opt in
  f) FILTER="$OPTARG" ;;
  w) IGNORE_WHITESPACE=true ;;
  s)
    SHOW_DIFF=true
    DIFF_FORMAT="-y"
    ;;
  u)
    SHOW_DIFF=true
    DIFF_FORMAT="-u"
    ;;
  c) COLOR_DIFF=true ;;
  ?)
    echo "Invalid option"
    exit 1
    ;;
  esac
done

[ ! -d "$FOLDER1" ] && echo "Error: $FOLDER1 not found" && exit 1
[ ! -d "$FOLDER2" ] && echo "Error: $FOLDER2 not found" && exit 1

if [ "$COLOR_DIFF" = true ] && ! command -v colordiff >/dev/null 2>&1; then
  echo "Error: colordiff not installed. Install with 'brew install colordiff'"
  exit 1
fi

cd "$FOLDER1" || exit 1
find . -type f -name "$FILTER" | while read -r file; do
  file="${file#./}"

  if [ -f "$FOLDER2/$file" ]; then
    if [ "$IGNORE_WHITESPACE" = true ]; then
      DIFF_CMD="diff -w"
    else
      DIFF_CMD="diff"
    fi

    if [ "$SHOW_DIFF" = true ]; then
      if [ "$COLOR_DIFF" = true ]; then
        $DIFF_CMD "$DIFF_FORMAT" "$FOLDER1/$file" "$FOLDER2/$file" >/dev/null 2>&1
        if [ $? -eq 1 ]; then
          echo "Differences in: $file"
          $DIFF_CMD "$DIFF_FORMAT" "$FOLDER1/$file" "$FOLDER2/$file" | colordiff
          echo "----------------------------------------"
        fi
      else
        $DIFF_CMD "$DIFF_FORMAT" "$FOLDER1/$file" "$FOLDER2/$file" >/dev/null 2>&1
        if [ $? -eq 1 ]; then
          echo "Differences in: $file"
          $DIFF_CMD "$DIFF_FORMAT" "$FOLDER1/$file" "$FOLDER2/$file"
          echo "----------------------------------------"
        fi
      fi
    else
      $DIFF_CMD "$FOLDER1/$file" "$FOLDER2/$file" >/dev/null 2>&1
      [ $? -eq 1 ] && echo "Files differ: $file"
    fi
  fi
done

echo "Comparison complete"
